{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [":NODE:", [":PACKAGE:", "!@shared", "!@shared/**"], ["@shared", "@shared/**", "@/**"], ":PATH:"]
          }
        }
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineWidth": 120
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "asNeeded",
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "correctness": {
        "noUnusedVariables": "error"
      },
      "style": {
        "noDescendingSpecificity": "off"
      },
      "suspicious": {
        "noDoubleEquals": "off",
        "useIterableCallbackReturn": "off",
        "noExplicitAny": "error",
        "noRedundantUseStrict": "off",
        "noAssignInExpressions": "off"
      },
      "complexity": {
        "useArrowFunction": "off",
        "noStaticOnlyClass": "off",
        "noThisInStatic": "off"
      },
      "nursery": {
        "useExplicitType": "error"
      }
    }
  }
}
