[Unit]
Description=nginx

[Service]
Type=forking
ExecStartPre=/usr/local/sbin/nginx -t
ExecStart=/usr/local/sbin/nginx
ExecReload=/usr/local/sbin/nginx -s reload
KillSignal=TERM
ExecStop=/bin/kill -s QUIT $MAINPID
User=root
WorkingDirectory=/usr/local/sbin/
Restart=on-failure

[Install]
WantedBy=multi-user.target
