<% if @context.logged_in_or_guest? || controller_name == "main" && action_name == "index" %>
  <nav class="navbar navbar-expand-lg">
    <div class="container-fluid">
      <div class="nav-links nav navbar-nav navbar-left">
        <div class="navbar-header">
          <%= link_to image_tag("precisionFDA.white.navbar.png", alt: "PrecisionFDA Home", height: "33px"), root_path, class: "navbar-brand", data: { turbolinks: false } %>
          <a class="nav-item" href="/home" data-turbolinks="false">
            <span class="fa fa-fw fa-arrow-left"></span>
            Back Home
          </a>
        </div>
      </div>

      <div id="pfda-navbar-collapse">
        <% if @context.logged_in_or_guest? %>
          <% if inside_of_spaces? %>
            <%= render "_partials/nav_links_spaces" %>
          <% elsif inside_of_space_item?(@space) %>
            <%= render "_partials/nav_links_space_item" %>
          <% end %>
          <%= render "_partials/nav_user" %>
        <% else %>
          <ul class="nav navbar-nav navbar-right">
            <li>
              <%= link_to login_path, class: "btn accessible-btn-link btn-lg", data: { no_turbolink: true } do %>
                <span class="fa fa-fw fa-sign-in" aria-hidden="true"></span> Log in
              <% end %>
            </li>
          </ul>
        <% end %>
      </div>
    </div>
  </nav>
  <%= render "_partials/fisma_banner", :dynamic_id => 'FISMA security information 1'  %>
  <%= render "_partials/modal_notification_settings" %>
<% end %>

<%= render "_partials/modal_external_link_notify" %>
<%= render "_partials/cloud_resources_modal" %>
