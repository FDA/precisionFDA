<%
  can_be_public = item.publishable_by?(@context, Scopes::SCOPE_PUBLIC)
%>

<% if can_be_public %>
  <%= link_to publish_path + "?" + { identifier: item.uid, type: "comparison" }.to_param, method: :get, class: "btn btn-success #{defined?(classes) ? classes : ''}" do %>
    <span class="fa fa-bullhorn"></span> Publish publicly
  <% end %>
<% end %>
