{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "root": false,
  "extends": "//",
  "files": {
    "includes": ["src/**", "!src/features/lexi", "biome.json"]
  },
  "linter": {
    "rules": {
      "nursery": {
        "useExplicitType": "off"
      },
      "correctness": {
        "noUnusedVariables": "warn"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noImportCycles": "warn"
      }
    }
  }
}
