# E2E Test Environment Variables
# Copy this file to .env.e2e and fill in the values

# Base URL for the application (local Docker Compose environment)
BASE_URL=https://localhost:3000

# Test user credentials
# These should be credentials for a test user in your local environment
# See packages/rails/lib/tasks/users_dev.yml for available test users
# Use the dxuser value (username), not the email
TEST_USER_USERNAME=randall.ebert
TEST_USER_PASSWORD=password

# Additional test users for member management tests
# These are used in spaces-members.spec.ts for testing member add/remove functionality
TEST_REGULAR_USER=pfda_autotest1
TEST_REGULAR_GOV_USER=password

# Admin user credentials for challenge creation tests
# This user must have can_create_challenges permission set to true
TEST_ADMIN_USERNAME=cypress.admin
TEST_ADMIN_PASSWORD=password

# Second admin user for challenge tests (used as guest lead and scoring app owner)
# Must be a different user than TEST_ADMIN_USERNAME
# This user creates and publishes the scoring app for challenges
TEST_ADMIN2_USERNAME=randall.ebert
TEST_ADMIN2_PASSWORD=password

# Secondary user credentials for multi-user tests (e.g., joining challenges)
# This should be a regular user without admin privileges
TEST_SECONDARY_USERNAME=sirius.black
TEST_SECONDARY_PASSWORD=password

# DNAnexus OAuth credentials (if testing the OAuth flow)
# Usually not needed for local development with seeded test users
DNANEXUS_AUTH_URL=https://auth.dnanexus.com
