    "@types/luxon": "^3.7.1",
    "@types/mjml": "^4.7.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.10",
    "@types/nodemailer": "^7.0.11",
    "@types/ramda": "^0.31.1",
    "@types/sinon": "^21.0.0",
    "@types/supertest": "^7.2.0",
    "@types/tough-cookie": "^4.0.5",
    "@types/ws": "8.18.1",
    "chai": "^4.2.0",
    "chai-as-promised": "^7.1.2",
    "chance": "^1.1.13",
    "dirty-chai": "^2.0.1",
    "esbuild": "^0.27.4",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "json-schema": "^0.4.0",
    "luxon": "^3.7.2",
    "mocha": "^11.7.5",
    "node-hmr": "^1.4.0",
    "sinon": "^21.0.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "wds": "^0.24.2"
  },
  "pnpm": {
    "overrides": {
      "html-minifier": "npm:html-minifier-terser@^6.1.0"
    }
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@shared/shared(|/.*)$": "<rootDir>/libs/shared/src/$1"
    }
  }
}
