{
  "name": "server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "format": "biome format --write apps libs",
    "format:check": "biome format apps libs",
    "build": "npm run build:api && npm run build:worker && npm run build:admin-platform-client",
    "build:api": "nest build api",
    "start:api": "nest start api",
    "start:dev:api": "nest start api --watch",
    "start:debug:api": "nest start api --debug --watch",
    "start:prod:api": "node -r ./tracing-loader.js dist/apps/api/apps/api/src/index",
    "clean": "rm -rf ./dist && rm -rf tsconfig.build.tsbuildinfo",
    "uninstall": "rm -rf ./node_modules",
    "build:worker": "nest build worker",
    "start:worker": "nest start worker",
    "start:dev:worker": "nest start worker --watch",
    "start:debug:worker": "nest start worker --debug 9228 --watch",
    "start:prod:worker": "node -r ./tracing-loader.js dist/apps/worker/apps/worker/src/index",
    "build:admin-platform-client": "nest build admin-platform-client",
    "start:admin-platform-client": "nest start admin-platform-client",
    "start:dev:admin-platform-client": "nest start admin-platform-client --watch",
    "start:debug:admin-platform-client": "nest start admin-platform-client --debug 9227 --watch",
    "start:prod:admin-platform-client": "node -r ./tracing-loader.js dist/apps/admin-platform-client/apps/admin-platform-client/src/index",
    "lint": "biome lint apps libs",
    "lint:fix": "biome lint --write --unsafe apps libs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/api/test/jest-e2e.json"
  },
