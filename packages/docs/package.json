{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build": "next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/",
    "dev": "next dev -p 4040",
    "start": "PORT=4040 node .next/standalone/server.js",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@r4ai/remark-callout": "^0.6.2",
    "fumadocs-core": "15.2.5",
    "fumadocs-mdx": "11.6.1",
    "fumadocs-ui": "15.2.5",
    "lucide-react": "^0.487.0",
    "next": "15.5.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rehype-raw": "^6.1.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.3",
    "@types/mdx": "^2.0.13",
    "@types/node": "22.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1",
    "eslint": "^8",
    "eslint-config-next": "15.5.4",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "overrides": {
      "server>html-minifier": "npm:html-minifier-terser@^6.1.0"
    }
  }
}
