# List of env variables that are used in docker compose 

# Speedup util - skips ruby deps installation - ASSUMES PRESENCE IN CACHE
SKIP_RUBY_DEPS_SETUP=0
# Speedup util - skips bower deps installation - ASSUMES PRESENCE IN CACHE
SKIP_BOWER_DEPS_SETUP=0
# Speedup util - skips nodejs api and worker deps installation - ASSUMES PRESENCE IN CACHE
SKIP_NODEJS_DEPS_SETUP=0
# Speedup util - skips nodejs api and worker waiting for database - ASSUMES DB INITIALIZED AND RUNNING
SKIP_NODEJS_DB_WAITING=0
# Speedup util - skips frontend deps installation
SKIP_FRONTEND_DEPS_SETUP=0
# Speedup util - skips running active record migration
SKIP_DB_SETUP=0

# Entrypoint configuration - Frequency of database polling - performed by nodejs-api and nodejs-worker
NODEJS_DB_POLLING_INTERVAL=5

# URL - nodejs API url
NODE_API_URL=https://host.docker.internal:3001
# URL - ruby API url
RUBY_API_URL=https://host.docker.internal:5012
DOCS_URL=http://host.docker.internal:4040
# for native node
# NODE_API_URL=https://host.docker.internal:3001

RECAPTCHA_SITE_KEY=NEED_A_KEY_4_TEST
