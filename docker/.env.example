# List of env variables that are used in docker compose 

# ======= DOCKER BUILD =======
# Image version overrirdes

RUBY_IMAGE_TAG=
NODEJS_IMAGE_TAG=
FRONTEND_IMAGE_TAG=

MYSQL_IMAGE_TAG=

# ======= DOCKER UTILS =======
# Extracted because yarnv2 uses different caching mechanism

YARNV1_CACHE_DIR=/usr/local/share/.cache/yarn/v6

# ======= DOCKER EXPERIMENTAL SPEEDUP UTILS =======
# Private variables that shouldn't be versioned

SKIP_RUBY_DEPS_SETUP=0
SKIP_NODEJS_DEPS_SETUP=0
SKIP_FRONTEND_DEPS_SETUP=0
SKIP_DB_SETUP=0

# ======= DOCKER PLATFORM SPECIFIC FLAGS ======
ARM64V8_DEVELOPMENT_PATCH=0

# ======= WORKAROUNDS =======
# This workaround is because of isolation.docker-compose.yml
# 2 different issues were encountered
# * there are some errors related to CSRF token that has to be encountered on backend by using different RAILS_ENV
#   * Therefore RAILS_ENV is set to "development"
# * Database setup for QA doesn't work when RAILS_ENV isn't directly defined in isolation.docker-compose.yml
#   * Therefore RAILS_ENV has to be in isolation.docker-compose.yml and set to "ui_test"
# For those reasons extracted here, to maintain 2 different versions of docker compose

# INTEL_RAILS_ENV=development

# TODO(samuel) reorganize .env variables
