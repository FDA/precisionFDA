user www-data;
worker_processes auto;
pid /var/run/nginx.pid;
error_log <%= node[:nginx][:log_dir] %>/nginx_error.log warn;

events {
  worker_connections 1024;
  use epoll;
  multi_accept on;
}

http {
  server_tokens off;
  client_max_body_size 50M;
  keepalive_requests 100000;
  keepalive_timeout 120;
  send_timeout 120;

  include /etc/nginx/conf.d/json_analytics_log_format_for_prometheus.conf;

  server {
    listen 80;

    # The following is needed for AUTHENTICATION_HEADER_NAME and AUTHENTICATION_HEADER_NAME_EMAIL
    underscores_in_headers on;

    location /ginas/app {
      proxy_pass http://localhost:8080;
      proxy_pass_request_headers on;
    }
  }
}
