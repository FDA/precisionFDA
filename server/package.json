{
  "name": "server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "build": "npm run build:api && npm run build:worker",
    "build:api": "nest build api",
    "start:api": "nest start api",
    "start:dev:api": "nest start api --watch",
    "start:debug:api": "nest start api --debug --watch",
    "start:prod:api": "node dist/apps/api/apps/api/src/index",
    "clean": "rm -rf ./dist && rm -rf tsconfig.build.tsbuildinfo",
    "uninstall": "rm -rf ./node_modules",
    "build:worker": "nest build worker",
    "start:worker": "nest start worker",
    "start:dev:worker": "nest start worker --watch",
    "start:debug:worker": "nest start worker --debug 9228 --watch",
    "start:prod:worker": "node dist/apps/worker/apps/worker/src/index",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/api/test/jest-e2e.json"
  },
