# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

# Ignore bundler config.
/.bundle

# Ignore the default SQLite database.
/db/*.sqlite3
/db/*.sqlite3-journal

# Ignore database config
/config/database.yml

# Ignore Rspec code coverage data
/coverage/*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
*.swp

# Ignore uploaded files in development
/storage/*
!/storage/.keep

/node_modules
/yarn-error.log

# Ignore generated assets
/public/assets

.byebug_history

# Ignore master key for decrypting credentials and more.
/config/master.key

# Ignore deployed gems
/vendor/bundle

# Ignore CSV in assets
/app/assets/csv

# Ignore OSX hidden file
.DS_Store

.gems/

# Ignore local environment
.env

# Ignore IDE files
.idea/

# Ignore application configuration
/config/application.yml

# Ignore autotest's config files
/test/functional/.idea
/test/functional/target
/test/functional/*.iml

#Ignore test browser drivers
/test/functional/drivers/chromedriver
/test/functional/drivers/geckodriver

#Ignore test temp files
/test/functional/src/main/resources/tempFiles/*.txt
/test/functional/src/main/resources/tempFiles/*.png
/test/functional/src/main/resources/tempFiles/Docker*
/test/functional/src/main/resources/tempFiles/*.gz
/test/functional/src/main/resources/tempFiles/*.csv

# Ignore local scripts
run-ui-test.sh
