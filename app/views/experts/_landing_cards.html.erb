<% if (experts.count > 0) %>
  <ul class="pfda-cards pfda-cards-list">
    <% experts.each do |e| %>
      <li class="pfda-card pfda-card-padded pfda-card-rounded pfda-card-default pfda-card-bordered">
        <div class="media">
          <div class="media-left media-middle">
            <%= image_tag(e.image, class: 'img-rounded', width: '250px') %>
            <br/>
            <div class="pfda-card-title text-center">
              <%= e.title %>
              <br/>
              <% if !e.user.singular? %>
                <i><%= e.user.org.name %></i>
              <% end %>
              <br/>
            </div>
          </div>
          <div class="media-body container-fluid container-padded text-center">
            <div class="pfda-card-title lead">
              My Challenge to the PrecisionFDA Community
            </div>
            <span class="text-muted"><%= local_date(e.created_at, '%B %e, %Y') %></span>
            <hr>
            <div class="pfda-card-body text-left">
              <%= simple_format(e._challenge, {class: "expert-font"})%>
            </div>
            <div class="btn-group">
              <%= link_to(content_tag(:span, "", class: "fa fa-star-o") + " Visit Expert Q/A", expert_path(e), class: 'btn btn-default') %>
            </div>
            <div class="btn-group">
            <%= link_to(content_tag(:span, "", class: "fa fa-newspaper-o") + " Read Expert Blog Post", blog_expert_path(e), class: 'btn btn-default') %>
            </div>
          </div>
        </div>
      </li>
    <% end %>
  </ul>
<% end %>
