<% if (experts.count > 0) %>
  <div class="pfda-cards pfda-cards-list">
    <% experts.each do |e| %>
     <div class="pfda-card pfda-card-list pfda-card-padded" >
      <div class="pfda-card-header">
        <div class="media">
          <div class="media-left text-muted center-block text-center">
            <%= link_to image_tag(e.image, class: 'img-circle', height: '50px'), expert_path(e) %>
          </div>
          <div class="media-body text-center">
            <div class="pfda-card-title">
              <%= link_to e.name, expert_path(e) %>
            </div>
            <ul class="pfda-card-metadata pfda-card-metadata-glued list-inline list-inline-bullets">
              <li><%= e.user.org.handle %>/<%= e.user.dxuser %></li>
              <li><%= e.created_at.to_s(:db) %></li>
            </ul>
            <ul class="pfda-card-metadata pfda-card-metadata-glued list-inline list-inline-bullets">
              <li title="Questions"><span class="pfda-card-metadata-value"><%= e.expert_questions.count %></span> Questions</li>
              <li title="Answers"><span class="pfda-card-metadata-value"><%= e.expert_answers.count %></span> Answers</li>
            </ul>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="alert alert-info">
    We couldn't find any experts here
  </div>
<% end %>
