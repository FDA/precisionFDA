<% if (experts.count > 0) %>
  <div class="pfda-cards pfda-cards-list">
    <% experts.each do |e| %>
    <div class="pfda-card pfda-card-list pfda-card-padded">
      <div class="pfda-card-header">
        <div class="media">
          <div class="media-left text-muted center-block text-center">
            <%= link_to image_tag(e.image, class: 'img-circle', height: '50px'), expert_path(e) %>
          </div>
          <div class="media-body text-center">
            <div class="pfda-card-title">
              <%= link_to e.name, expert_path(e) %>
            </div>
            <ul class="pfda-card-metadata pfda-card-metadata-glued list-inline list-inline-bullets">
              <li><%= e.user.org.handle %>/<%= e.user.dxuser %></li>
              <li><%= local_date(e.created_at, '%B %e, %Y') %></li>
            </ul>
            <ul class="pfda-card-metadata pfda-card-metadata-glued list-inline list-inline-bullets">
              <li><span class="pfda-card-metadata-value"><%= e.answered_questions.count %></span> <%= "Answer".pluralize(e.answered_questions.count) %></li>
              <li><span class="pfda-card-metadata-value"><%= e.commented_questions.count %></span> <%= "Comment".pluralize(e.commented_questions.count) %></li>
            </ul>
          </div>
        </div>
      </div>
      <% if e.editable_by?(@context) %>
        <br/>
        <div class="text-center">
          <%= link_to dashboard_expert_path(e), class: 'btn btn-default' do %>
            <span class="fa fa-dashboard fa-fw"></span> View Your Expert Dashboard
          <% end %>
        </div>
      <% end %>
    </div>
    <% end %>
  </div>
<% else %>
  <div class="alert alert-info text-center">
    We couldn't find any experts here.
  </div>
<% end %>
