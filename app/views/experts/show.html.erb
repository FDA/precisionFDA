<% content_for :title do %><%= @expert.name %><% end %>
<div class="page-header">
  <div class="media">
    <div class="media-left text-muted">
     <%= image_tag(@expert.image, class: 'img-square', height: '100px', width: '100px') %>
    </div>
    <div class="media-body">
      <% if @expert.editable_by?(@context) %>
        <div class="pull-right">
          <div class="btn-group">
            <div class="dropdown">
              <button class="btn btn-link btn-lg" id="dLabel" type="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                <span class="fa fa-cog"></span>
              </button>
              <ul class="dropdown-menu dropdown-menu-right" aria-labelledby="dLabel">
                <li>
                  <%= link_to edit_expert_path(@expert) do %>
                    <span class="fa fa-pencil"></span> Edit
                  <% end %>
                </li>
              </ul>
            </div>
          </div>
        </div>
      <% end %>

      <div class="page-title">
        Expert Q&A with <%= link_to("#{@expert.name}", user_path(@expert.user.dxuser)) %> (<%= @expert.user.org.name %>)
      </div>
      <div class="pfda-discussion-content">
        <%= @expert._intro %>
      </div>
    </div>
    <div class="pfda-pane container-padded container-fluid">
      <div class="pfda-pane-content">
        <% if @answered_questions.count > 0 %>
          <% @answered_questions.each do |q|%>
            <li class="list-group-item list-group-item-header">
              <%= q.body %>
            </li>
            <li class="list-group-item">
              <%= q.expert_answer.body %>
            </li>
          <% end %>
        <% else %>
          No questions have been answered yet.
        <% end %>
      </div>
      <div class="pfda-pane-sidebar pfda-pane-sidebar-minimal pfda-pane-sidebar-padded-v">
        <div class="list-group">
          <li class="list-group-item text-center">
            <a class="btn btn-primary" data-toggle="modal" data-target="#ask-question-modal">
              <span class="fa fa-commenting-o fa-fw" aria-hidden="true"></span> Ask <%= @expert.user.first_name.capitalize %>
            </a>
          </li>
          <% if @context.logged_in? %>
            <% if @user_questions.count > 0 %>
              <li class="list-group-item list-group-item-header">
                Your Questions (<%= @user_questions.count %>)
              </li>
              <% @user_questions.each do |q|%>
                <li class="list-group-item">
                  <%= q._original %>
               </li>
              <% end %>
            <% end %>
          <% else %>
            <li class="list-group-item">
              Please login or register for an account to see track your question history.
            </li>
          <% end %>
          <br/>
        </div>
        <div class="list-group">
          <li class="list-group-item list-group-item-header">
            About this month's Expert
          </li>
          <li class="list-group-item">
            <%= @expert._bio %>
          </li>
        </div>
      </div>
    </div>
  </div>
</div>

<%= render "experts/modal_ask_question" %>
