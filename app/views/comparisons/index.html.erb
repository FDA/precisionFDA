<% content_for :title do %>Comparisons<% end %>

<%= render "_partials/toolbar", toolbar: @toolbar  %>

<%= grid(@comparisons_grid, show_filters: :when_filtered) do |g|
  g.blank_slate partial:  "_partials/empty_grid"

  g.after_row do |comparison, num_cols|
    if comparison.description
      content_tag(:tr,
        content_tag(:td,
          content_tag(:div, comparison.description, class: 'description'),
        colspan: num_cols),
      class: 'extra-row')
    else
      nil
    end
  end

  g.column name: 'Name', attribute: 'name' do |comparison|
    link_to(comparison.name, comparison_path(comparison.id))
  end

  g.column name: 'State', attribute: 'state' do |comparison|
    comparison.state
  end

  g.column name: 'Added by', attribute: 'dxuser', assoc: :user do |comparison|
    link_to(comparison.user.dxuser, user_path(comparison.user.dxuser))
  end

  # g.column name: 'Test Variant' do |comparison|
  #   input = comparison.inputs
  #   debug input
  #   # link_to(comparison.user_files.accessible_by(@context.user_id).size, file_path())
  # end

  g.column name: 'Created', attribute: 'created_at', auto_reload: true, filter_type: :standard do |file|
    file.created_at.to_s(:db)
  end

  g.column name: 'Updated', attribute: 'updated_at', auto_reload: true, filter_type: :standard do |comparison|
    comparison.updated_at.to_s(:db)
  end
end -%>
