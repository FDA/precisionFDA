<div class="container container-padded">
  <div class="pfda-challenge-intro">
    <div class="lead-intro">The precisionFDA Truth Challenge ran from April 26, 2016 to May 26, 2016, inviting participants to process two datasets through their NGS processing pipeline and publish results on precisionFDA for subsequent evaluation against truth data.</div>
    <div class="lead">
       Community members from four different continents embraced the challenge...</div>
  </div>
</div>

<div class="challenge-section challenge-section-highlight pfda-challenge-awards">
  <div class="container container-padded">
      <div class="h3 text-center text-uppercase">Community Challenge Awards
      <br>
      <small>Revealed <%= @truth_challenge[:results_date] ? "in " + distance_of_time_in_words_to_now(@truth_challenge[:results_date]) : "soon" %></small></div>
      <div class="row">
        <div class="col-md-8 col-md-offset-8">
          <div class="pfda-cards pfda-cards-justify-centered">
            <div class="pfda-card pfda-card-rounded">
              <div class="pfda-card-body">
                <%= medal_badge("Performance", "Top overall", "large") %>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="row">
        <div class="col-md-8 col-md-offset-4">
          <div class="pfda-cards pfda-cards-justify-centered">
            <div class="pfda-card pfda-card-rounded">
              <div class="pfda-card-body">
                <%= medal_badge("Reproducibility", "Highest", "large") %>
              </div>
            </div>
          </div>
        </div>
        <div class="row">
          <div class="col-md-8">
            <div class="pfda-cards pfda-cards-justify-centered">
              <div class="pfda-card pfda-card-rounded">
                <div class="pfda-card-body">
                  <%= medal_badge("Accuracy", "Highest", "large") %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
