<ul class="pfda-post-metadata list-inline list-inline-bullets">
  <li>
    <%= link_to image_tag(event.item.user.gravatar_url, class: 'img-circle', height: '20px'), user_path(event.item.user.dxuser) %>
    <span class="pfda-post-user"><%= link_to event.item.user.full_name, user_path(event.item.user.dxuser) , class: 'link-dark'%></span> posted <%= indefinitize(event.item.klass) %>
  </li>
  <li class="pfda-post-org">
    <%= event.item.user.org.name %>
  </li>
  <li>
    <%= event.timestamp.to_s(:db) %>
  </li>
</ul>
