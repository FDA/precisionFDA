<div class="pfda-comments">
  <% if !feed.nil? and feed.size > 0 %>
    <% feed.each do |event| %>
      <% case event.item_type %>
      <% when "comment" %>
        <%= render "spaces/comment", event: event %>
      <% when "task" %>
        <%= render "spaces/task", event: event %>
      <% else %>
        <%= render "spaces/event", event: event %>
      <% end %>
    <% end %>
  <% else %>
    <div class="text-muted">No posts yet.</div>
  <% end %>
</div>
