<% apps.each do |app| %>
  <a href="<%= app_jobs_path(app.dxid) %>"
    class="list-group-item app-<%= app.app_series_id %> <%= app.app_series_id == active ? 'active' : ''%>"
    data-app="<%= app.dxid %>">
    <%= app.title %>
    <br>
    <small class="text-muted"><%= app.user.org.handle %>/<%= app.user.dxuser %></small>
  </a>
<% end %>
