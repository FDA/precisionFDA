<% if item.copyable_to_cooperative_by?(@context) %>
  <%= button_to copy_to_cooperative_space_path(item.space_object, object_id: item.uid), method: :post, form_class: "btn-block", class: "btn btn-success btn-block", data: { disable_with: 'Copying...',  confirm: 'Are you sure you want to copy this?'} do %>
    <span class="fa fa-copy"></span> Copy to Cooperative
  <% end %>
<% end %>
