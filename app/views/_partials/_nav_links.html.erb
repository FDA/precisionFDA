<% if @context.logged_in? %>
<ul class="nav-links nav navbar-nav">
  <li class="<%= 'active' if params[:controller] == 'main' %>" role="presentation">
    <%= link_to root_path do %>
      <div class="nav-icon fa fa-2x fa-home"></div>
      <div class="nav-pill-title">Overview</div>
    <% end %>
  </li>
  <li class="<%= 'active' if params[:controller] == 'files' %>" role="presentation">
    <%= link_to files_path do %>
      <div class="nav-icon fa fa-2x fa-files-o"></div>
      <div class="nav-pill-title">Files</div>
    <% end %>
  </li>
  <li class="<%= 'active' if params[:controller] == 'comparisons' %>" role="presentation">
    <%= link_to comparisons_path do %>
      <div class="nav-icon fa fa-2x fa-bullseye"></div>
      <div class="nav-pill-title">Comparisons</div>
    <% end %>
  </li>
  <li class="<%= 'active' if params[:controller] == 'apps' %>" role="presentation">
    <%= link_to apps_path do %>
      <div class="nav-icon fa fa-2x fa-cubes"></div>
      <div class="nav-pill-title">Apps</div>
    <% end %>
  </li>
  <li class="<%= 'active' if params[:controller] == 'notes' %>" role="presentation">
    <%= link_to notes_path do %>
      <div class="nav-icon fa fa-2x fa-sticky-note"></div>
      <div class="nav-pill-title">Notes</div>
    <% end %>
  </li>
</ul>
<% end %>

<ul class="nav navbar-nav navbar-right">
  <% if @context.logged_in? %>
    <li><%= link_to("Feedback", "https://docs.google.com/forms/d/1zfGoy-4C9kLbHHg0Y-6iQoI3fdGq1IfugV9fXCqOBfY/viewform?entry.2135861629=#{@context.username}&entry.864840924", target: "_blank") %></li>
  <% else %>
    <li><%= link_to("Learn more", "#TBD", target: "_blank") %></li>
    <li><%= link_to("Feedback", "https://docs.google.com/forms/d/1zfGoy-4C9kLbHHg0Y-6iQoI3fdGq1IfugV9fXCqOBfY/viewform", target: "_blank") %></li>
  <% end %>
  <li><a href="#">Docs</a></li>
  <% if @context.logged_in? %>
    <li class="dropdown">
      <a href="#" class="dropdown-toggle" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false"><%= @context.username %> <span class="caret"></span></a>
      <ul class="dropdown-menu">
        <li><%= link_to "Profile", user_path(@context.username) %></li>
        <li role="separator" class="divider"></li>
        <li><%= link_to "Log out", logout_path, method: :delete %></li>
      </ul>
    </li>
  <% else %>
    <li><a href="/login">Log In</a></li>
  <% end %>
</ul>
