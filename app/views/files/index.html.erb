<% content_for :title do %>Files<% end %>

<div class="pfda-toolbar">
  <ul class="nav nav-pills nav-pills-center nav-pills-sm">
    <li class="<% if action_name == 'index' %>active<% end %>">
      <%= link_to files_path do %>
        <span class="fa fa-files-o"></span> <span class="pill-label">My Files</span>
      <% end %>
    </li>
    <li class="<% if action_name == 'featured' %>active<% end %>">
      <%= link_to featured_files_path do %>
        <span class="fa fa-flag"></span> <span class="pill-label">Featured</span>
      <% end %>
    </li>
    <li class="<% if action_name == 'explore' %>active<% end %>">
      <%= link_to explore_files_path do %>
        <span class="fa fa-globe"></span> <span class="pill-label">Explore</span>
      <% end %>
    </li>
  </ul>
</div>

<div class="pfda-toolbar">
  <div class="btn-group">
    <a class="btn btn-primary" href="<%= new_file_path %>">
      <span class="fa fa-plus-square fa-fw"></span> Add files
    </a>
  </div>
</div>

<% if @files_grid.present? %>
  <%= grid(@files_grid, show_filters: :when_filtered) do |g|
    g.blank_slate partial:  "_partials/empty_grid"

    g.after_row do |file, num_cols|
      if !file.description.blank?
        content_tag(:tr,
          content_tag(:td,
            content_tag(:div, file.description, class: 'description'),
          colspan: num_cols),
        class: 'extra-row')
      else
        nil
      end
    end

    g.column name: 'Name', attribute: 'name' do |file|
      unilinkfw(file, globe: true)
    end

    g.column name: 'Added by', attribute: 'dxuser', assoc: :user do |file|
      link_to(file.user.dxuser, user_path(file.user.dxuser))
    end

    g.column name: 'Size', attribute: 'file_size' do |file|
      number_to_human_size(file.file_size)
    end

    g.column name: 'Origin' do |file|
      if file.parent_type != "User"
        unilinkfw(file.parent)
      else
        "Uploaded"
      end
    end

    g.column name: 'Created', attribute: 'created_at', auto_reload: true, filter_type: :standard do |file|
      file.created_at.to_s(:db)
    end

    g.column name: 'State', attribute: 'state', custom_filter: :auto

    g.column name: 'Access', attribute: 'scope',
      custom_filter: {'Public' => "public", 'Private' => "private"} do |file|
      file.public? ? "Public" : "Private"
    end

    if @grid_options && @grid_options.has_key?(:action)
      action = @grid_options[:action]
      g.column do |file|
        link_to(action[:label], action[:path], class: action[:className], data: {file_id: file.id})
      end
    end
  end -%>
<% else %>
  <div class="alert alert-info">
    <% if action_name == 'index' %>
      <span class="fa fa-info-circle"></span> Files you add will show up here. Meanwhile, check out our <%= link_to "Featured Files", featured_files_path %> or <%= link_to "explore community contributions", explore_files_path %>
    <% else %>
      We couldn't find any files here
    <% end %>
  </div>
<% end %>
