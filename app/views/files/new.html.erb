<% content_for :title do %>Upload File(s)<% end %>

<div class="page-header clearfix">
  <h1 class="pull-left"><span class="fa fa-file fa-fw"></span> Upload File(s)</h1>
</div>

<div class="container-fluid">
  <div class="section-files panel panel-default">
    <div class="panel-body">
      <form class="form form-upload-files">
        <div class="section-metadata form-group">
          <label class="control-label text-muted">Set Biospecimen (optional)</label>
          <div class="control-group">
            <select name="biospecimen_id" class="field-biospecimen form-control">
                <option></option>
              <% @biospecimens.each do |biospecimen| %>
                <option value="<%= biospecimen.id %>"><%= biospecimen.name %><%= biospecimen.description ? " - #{biospecimen.description}" : "" %></option>
              <% end %>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label class="control-label">Files <span class="upload-state label" style="display:none;" data-bind="visible: isUploadStateVisible, text: uploadStateDisplay"></span></label>

          <div class="control-group">
            <span class="btn btn-primary btn-browse-files" data-bind="visible: isBrowseVisible">
                Browse files for upload... <input class="event-browse-files" type='file' multiple required>
            </span>

            <button class="btn btn-primary event-upload-files" style="display:none;" data-bind="visible: isUploadVisible">
              <span class="fa fa-cloud-upload fa-fw"></span> Upload
            </button>
            <button class="btn btn-default event-clear-files" style="display:none;" data-bind="visible: isClearVisible">Clear files</button>
          </div>
        </div>
      </form>
    </div>

    <ul class="list-group list-files" style="display:none;" data-bind="visible: files().length > 0, foreach: files">
      <li class='list-group-item' data-bind="css: classes">
        <h4 class='list-group-item-heading'>
          <span data-bind="text: file.name"></span> <span class="file-metadata-glue">&middot;</span> <small data-bind="text: file.type || 'File'"></small> <span class="file-metadata-glue">&middot;</span>  <small data-bind="text: sizeFormatted"></small></h4>
        <div class='list-group-item-text'>
          <input type='text' class='file-description form-control' placeholder='Add description...' data-bind="visible: isDescriptionVisible ,value: description">
        </div>
        <div class='progress' data-bind="visible: isProgressVisible">
          <div class='progress-bar progress-bar-striped active' role='progressbar' aria-valuenow='100' aria-valuemin='0' aria-valuemax='100' style='min-width: 2%' data-bind="style: {width: progressPercentFormatted}">
          </div>
        </div>
      </li>
    </ul>
  </div>

</div>
