<%= grid(invitations) do |g|
  g.column name: "First Name", attribute: "first_name" do |invitation|
    content_tag(:span, invitation.first_name)
  end

  g.column name: "Last Name", attribute: "last_name" do |invitation|
    content_tag(:span, invitation.last_name)
  end

  g.column name: "Email", attribute: "email" do |invitation|
    content_tag(:span, invitation.first_name)
  end

  g.column name: "Address 1", attribute: "address1" do |invitation|
    content_tag(:span, invitation.address1)
  end

  g.column name: "Address 2", attribute: "address2" do |invitation|
    content_tag(:span, invitation.address2)
  end

  g.column name: "Country", attribute: "name", assoc: :country do |invitation|
    content_tag(:span, invitation.country.name)
  end

  g.column name: "City", attribute: "city" do |invitation|
    content_tag(:span, invitation.city)
  end

  g.column name: "US State", attribute: "us_state" do |invitation|
    content_tag(:span, invitation.us_state)
  end

  g.column name: "Postal Code", attribute: "postal_code" do |invitation|
    content_tag(:span, invitation.postal_code)
  end

  g.column name: "Phone", attribute: "phone" do |invitation|
    content_tag(:span, invitation.phone)
  end

  g.column name: "DUNS", attribute: "duns" do |invitation|
    content_tag(:span, invitation.duns)
  end

  g.column name: "First Name", attribute: "first_name" do |invitation|
    content_tag(:span, invitation.first_name)
  end
end
%>
