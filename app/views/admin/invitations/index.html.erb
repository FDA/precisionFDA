<% content_for :title, "Invitations" %>

<div class="page-header">
  <div class="page-title">Invitations</div>
</div>

<div class="pfda-padded invitations-search">
  <div class="invitations-search-input">
    <input
      type="text"
      id="search_input"
      class="form-control input-lg"
      placeholder="Search user by First name, Last name or Email..."
    />
  </div>
  <div class="invitations-search-browse">
    <button class="btn btn-success btn-lg" data-bind="click: showGridModal">Browse</button>
    <%= render "admin/invitations/grid_modal" %>
  </div>
</div>

<!-- ko if: invitations().length -->
<div class="pfda-padded invitations">
  <%= render "admin/invitations/invitations_table" %>
  <%= render "admin/invitations/disable_screen_modal" %>
  <div class="pfda-padded-v">
    <button class="btn btn-primary btn-lg" data-bind="click: provisionUsers">Submit</button>
    <button class="btn btn-default btn-lg" data-bind="click: clearInvitations">Clear</button>
  </div>
</div>
  <!-- /ko -->
