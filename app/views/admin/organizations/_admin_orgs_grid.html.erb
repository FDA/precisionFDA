
<%= grid(@orgs_grid, show_filters: :always) do |g|

  g.column name: "Name", attribute: "name", auto_reload:true, filter: :string do |org|
    link_to org.name, admin_show_org_path(handle: org.handle)
  end

  g.column name: "Handle", attribute: "name", auto_reload:true, filter: :string do |org|
    org.handle
  end

  g.column name: "Address", attribute: "address", auto_reload:true, filter: :string do |org|
    org.address
  end

  g.column name: "Phone", attribute: "phone", auto_reload:true, filter: :string do |org|
    org.phone
  end

  g.column name: "Admin", attribute: "dxuser", assoc: :admin, filter: :string do |org|
    org.admin.dxuser rescue "No one"
  end
end
-%>