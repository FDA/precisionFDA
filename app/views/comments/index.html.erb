<% content_for :title do %>Comments for <%= @item.klass %>: <%= @item.title %><% end %>

<div class="page-header">
  <div class="page-title">
    <span class="fa fa-comments-o"></span> Comments for <%= @item.klass %>:
    <%= link_to @item.title, @item_path %>
  </div>
</div>

<div class="container-fluid container-padded">
  <%= render "comments/comments", comments: @comments, itemsFromParams: @itemsFromParams %>

  <hr>

  <% if !@context.guest? %>
  <div class="row pfda-comment">
    <div class="col-sm-12">
      <div class="media">
        <div class="media-left">
          <%= link_to image_tag(@context.user.gravatar_url, class: 'img-circle', height: '25px'), user_path(@context.user.dxuser) %>
        </div>
        <div class="media-body">
          <ul class="pfda-comment-meta list-inline list-inline-bullets text-muted">
            <li class="pfda-comment-user"><strong><%= link_to @context.user.full_name, user_path(@context.user.dxuser) %></strong></li>
            <li><%= @context.user.org.name %></li>
          </ul>
          <div class="pfda-comment-body">
            <%= render "comments/new_comment", url: @item_comments_path, object: @item %>
          </div>
        </div>
      </div>
    </div>
  </div>
  <% end %>
</div>
