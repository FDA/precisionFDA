<% content_for :title do %><%= @meta_appathon.title %><% end %>

<div class="pfda-meta-appathon-template pfda-meta-appathon-template-<%= @meta_appathon.template %>">
  <div class="jumbotron jumbotron-meta_appathon clearfix">
    <div class="row">

      <div class="col-sm-18 col-sm-offset-3 text-center col-lg-12 col-lg-offset-6">
        <h1>
          <span class="meta_appathon-title-muted">PrecisionFDA</span>
          <br>
          <%= @meta_appathon.title %>
        </h1>

        <p class="lead lead-intro">
          Help advance regulatory science, promote and discover NGS software, and contribute to the growing precisionFDA community, by organizing a precisionFDA app-a-thon.
        </p>

        <% if @context.logged_in? %>
          <% if !@meta_appathon.followed_by?(@context.user) && @meta_appathon.is_ongoing? %>
            <p class="text-center">
              <%= link_to new_meta_appathon_appathon_path(@meta_appathon), class: 'btn btn-danger btn-lg' do %>
                <span class="fa fa-bolt fa-fw"></span> Host an App-a-thon
              <% end %>
              <%= link_to "#appathons-list", class: 'btn btn-default btn-lg' do %>
                <span class="fa fa-laptop fa-fw"></span> View all App-a-thons
              <% end %>
            </p>
          <% elsif !@user_appathon.nil? %>
            <p class="text-center">
              <%= link_to appathon_path(@user_appathon), class: 'btn btn-default btn-lg' do %>
                <%= flag_image_tag(@user_appathon.flag, width: 25) %> <%= @user_appathon.title %> App-a-thon
              <% end %>
              <%= link_to "#appathons-list", class: 'btn btn-default btn-lg' do %>
                <span class="fa fa-laptop fa-fw"></span> View all App-a-thons
              <% end %>
            </p>
          <% end %>
        <% end %>
      </div>
      <div class="col-sm-12 col-sm-offset-6 col-lg-8 col-lg-offset-8">
        <%= image_tag("appathons/appathon-toolbox.png", class: 'img-responsive')  %>
      </div>
    </div>
  </div>

  <% if @meta_appathon.editable_by?(@context) %>
  <div class="pfda-toolbar">
    <%= link_to edit_meta_appathon_path(@meta_appathon), class: "btn btn-primary" do %>
      <span class="fa fa-pencil"></span> Edit
    <% end %>
  </div>
  <% end %>

  <div class="container-fluid pfda-meta-appathon-intro">
    <div class="thumbnail">
      <%= video_iframe("https://www.youtube.com/embed/ir662wQJ5cI") %>
    </div>
  </div>

  <div class="container-fluid container-padded pfda-meta-appathon-section">
    <div class="row">
      <div class="col-md-11">
        <div class="panel">
          <div class="panel-body">
            <div class="text-center">
              <%= image_tag("icons/ColoredLineIcons/png/128/bulletin_board.png")  %>
            </div>
            <div class="h3">
              What is an app-a-thon?
            </div>

            <p class="lead">
              An app-a-thon is your own community event where you and your peers, collaborators or friends get together and add your favorite NGS software to the precisionFDA app library.
            </p>
          </div>
        </div>

        <div class="panel">
          <div class="panel-body">
            <div class="text-center">
              <%= image_tag("icons/ColoredLineIcons/png/128/cloud.png")  %>
            </div>
            <div class="h3">
              What is a precisionFDA app?
            </div>

            <p class="lead">
              A precisionFDA app is a wrapper around NGS software, consisting of Linux executables and a specification of how to execute them in a Linux virtual machine. Apps can encapsulate any use case such as read mapping, variation calling, benchmarking, or simulations. Users on precisionFDA can try out these apps by running them directly on the cloud.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-12 col-md-offset-1">
        <div class="row">
          <div class="col-sm-offset-1 col-sm-10">
            <div class="panel panel-warning">
              <div class="panel-heading">
                <div class="metadata-section">
                  <ul class="list-group list-group-inline">
                    <li class="list-group-item list-group-item-transparent-bg">
                      <h5 class="list-group-item-heading">Start</h5>
                      <p class="list-group-item-text"><%= @meta_appathon.start_at.to_s(:db) %></p>
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
          <div class="col-sm-offset-2 col-sm-10">
            <div class="panel panel-warning">
              <div class="panel-heading">
                <div class="metadata-section">
                  <ul class="list-group list-group-inline">
                    <li class="list-group-item list-group-item-transparent-bg">
                      <h5 class="list-group-item-heading">End</h5>
                      <p class="list-group-item-text"><%= @meta_appathon.end_at.to_s(:db) %></p>
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>


        <div class="panel">
          <div class="panel-body">
            <div class="text-center">
              <%= image_tag("icons/ColoredLineIcons/png/128/lightbulb_idea.png")  %>
            </div>
            <div class="h3">
              Why organize or participate in an app-a-thon?
            </div>

            <p class="lead">
              By contributing to the precisionFDA app library, you help introduce your favorite NGS software to the FDA and to the community. When others do the same, you collectively help build up the precisionFDA app library, enabling the greater precisionFDA community to explore, access, and try out all these apps directly on the cloud.
            </p>

            <p class="lead">
              You also help disseminate the software in a portable manner, because users have the option of exporting the app as a Linux container and running it in any other environment.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="pfda-meta-appathon-kit">
    <div class="panel container container-padded">
      <div class="panel-body">
        <!-- Nav tabs -->
        <ul class="nav nav-pills nav-pills-center nav-pills-padded nav-pills-lg text-uppercase" role="tablist">
          <li role="presentation" class="active"><a href="#organizers" aria-controls="organizers" role="tab" data-toggle="tab">How to organize</a></li>
          <li role="presentation"><a href="#participants" aria-controls="participants" role="tab" data-toggle="tab">How to participate</a></li>
        </ul>
        <br/>
        <br/>
        <!-- Tab panes -->
        <div class="tab-content">
          <div role="tabpanel" class="tab-pane active" id="organizers">

            <div class="row">
              <div class="col-sm-2">
                <%= image_tag("icons/ColoredLineIcons/png/64/coffee.png", class: 'img-responsive')  %>
              </div>
              <div class="col-sm-5">
                <div class="h3">
                  Plan your app-a-thon
                </div>
              </div>
              <div class="col-sm-14 col-sm-offset-1">
                <p class="lead">
                  Think of how you want to organize your app-a-thon. Perhaps you are teaching a class and you'd like to devote a session or two to conduct an app-a-thon with your students. Or maybe you can invite your coworkers to stay in the office late one day and put apps on precisionFDA. Or you and your friends can connect online, and fiddle with precisionFDA over the course of two weeks. You can meet physically or virtually, and run the app-a-thon over any period of time, however short or long.
                </p>
              </div>
            </div>

            <div class="row">
              <div class="col-sm-2">
                <%= image_tag("icons/ColoredLineIcons/png/64/fountain_pen.png", class: 'img-responsive')  %>
              </div>
              <div class="col-sm-5">
                <div class="h3">
                  Obtain a contributor-level precisionFDA account
                </div>
              </div>
              <div class="col-sm-14 col-sm-offset-1">
                <p class="lead">
                  If you are part of an organization which already has access to precisionFDA, ask your organization's precisionFDA admin to provision an account for you. Otherwise, visit the precisionFDA home page and click <%= link_to "Request Access", request_access_path %>. Fill in the information and indicate that you are planning to organize an app-a-thon. The FDA acts as steward to providing the precisionFDA service to the community, so your request will be initially pending. In the meantime, you will receive an email with a link to access the precisionFDA website in browse (guest) mode. Later, once the FDA approves your account request, you will receive another email with your contributor account information.
                </p>
              </div>
            </div>

            <div class="row">
              <div class="col-sm-2">
                <%= image_tag("icons/ColoredLineIcons/png/64/bulletin_board.png", class: 'img-responsive')  %>
              </div>
              <div class="col-sm-5">
                <div class="h3">
                  Create an app-a-thon structure on precisionFDA
                </div>
              </div>
              <div class="col-sm-14 col-sm-offset-1">
                <p class="lead">
                  Visit the app-a-thon challenge page and click "Host an app-a-thon". Give your app-a-thon a name, a location, and optionally a description. Choose an icon that will represent your app-a-thon, and adjust its start date to when you want the app-a-thon to start. (We recommend leaving the end date to 10/31/2016, so that your participants have the opportunity to contribute additional apps even after you conclude your app-a-thon).
                </p>
              </div>
            </div>

            <div class="row">
              <div class="col-sm-2">
                <%= image_tag("icons/ColoredLineIcons/png/64/thumbs_up.png", class: 'img-responsive')  %>
              </div>
              <div class="col-sm-5">
                <div class="h3">
                  Ensure your app-a-thon's members have contributor-level precisionFDA accounts
                </div>
              </div>
              <div class="col-sm-14 col-sm-offset-1">
                <p class="lead">
                  If you are your organization's precisionFDA admin, and the members you want to recruit to your app-a-thon are from within your organization, visit your profile page and click "Provision new user". Enter the info (first name, last name, and email) for each user and provision them.
                </p>
              </div>
            </div>
          </div>

          <div role="tabpanel" class="tab-pane" id="participants">
            <div class="row">
              <div class="col-sm-2">
                <%= image_tag("icons/ColoredLineIcons/png/64/fountain_pen.png", class: 'img-responsive')  %>
              </div>
              <div class="col-sm-5">
                <div class="h3">
                  Obtain a contributor-level precisionFDA account
                </div>
              </div>
              <div class="col-sm-14 col-sm-offset-1">
                <p class="lead">
                  If the app-a-thon's organizer is in the same organization as you, they may have already provisioned an account for you. Otherwise, <%= link_to "file an access request", request_access_path %> and indicate that you plan to participate in an app-a-thon. The FDA acts as steward to providing the precisionFDA service to the community, so your request will be initially pending. In the meantime, you will receive an email with a link to access the precisionFDA website in browse (guest) mode. Later, once the FDA approves your account request, you will receive another email with your contributor account information.
                </p>
              </div>
            </div>

            <div class="row">
              <div class="col-sm-2">
                <%= image_tag("icons/ColoredLineIcons/png/64/bulletin_board.png", class: 'img-responsive')  %>
              </div>
              <div class="col-sm-5">
                <div class="h3">
                  Join the app-a-thon
                </div>
              </div>
              <div class="col-sm-14 col-sm-offset-1">
                <p class="lead">
                  Once the organizer creates an app-a-thon structure, the app-a-thon will appear in the precisionFDA list of app-a-thons. Visit the app-a-thon's page and click "Join". Note: this action cannot be undone, and the fact that you are a member of the app-a-thon will be publicly displayed.
                </p>
              </div>
            </div>

            <div class="row">
              <div class="col-sm-2">
                <%= image_tag("icons/ColoredLineIcons/png/64/laptop.png", class: 'img-responsive')  %>
              </div>
              <div class="col-sm-5">
                <div class="h3">
                  Learn how to make app assets and apps
                </div>
              </div>
              <div class="col-sm-14 col-sm-offset-1">
                <p class="lead">
                  Familiarize yourself with the system by running some of the existing apps, to get an idea of how apps work in general, and read the <%= link_to "Apps", show_docs_path('apps') %> section of the documentation. Click "Fork" on any app to take a look at its internals, and study the <%= link_to "Creating Apps", show_docs_path('creating_apps') %> section of the documentation, which includes an introductory video on making apps. Pay particular attention to the concept of app assets; you will most likely need to package NGS software into such an app asset, as part of making your app. If you do not have access to a Linux environment, download the precisionFDA VM as mentioned in the documentation.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="panel container container-padded">
      <div class="panel-body">
        <div class="text-center">
          <%= image_tag("icons/ColoredLineIcons/png/128/sunglasses.png")  %>
        </div>
        <div class="h3">
          Are you new to precisionFDA?
        </div>

        <p class="lead">
          Take a look at <a href="https://www.youtube.com/watch?v=U_vmcd93HkM" target="_blank">this 4-minute introductory video</a> to get an idea of what the system is about.
        </p>
      </div>
    </div>
  </div>

  <div id="appathons-list" class="pfda-meta-appathon-submissions container-fluid">
    <div class="panel panel-primary">
      <div class="panel-heading">
        <div class="text-center">
          <%= image_tag("icons/ColoredLineIcons/png/128/laptop.png")  %>
          <h4>App-a-thons and Submissions</h4>
        </div>
      </div>
      <div class="pfda-pane">
        <div class="pfda-pane-sidebar">
          <% if @context.logged_in? && @user_appathon.nil? %>
          <div class="pfda-toolbar">
            <div class="h4">
              Join or Organize an App-a-thon
            </div>
            <p class="text-muted">
              Help others discover great NGS software by contributing to this effort.
            </p>
            <% if !@meta_appathon.followed_by?(@context.user) && @meta_appathon.is_ongoing? %>
              <p class="text-muted">
                Organize or participate in a precisionFDA app-a-thon today!
              </p>
              <%= link_to new_meta_appathon_appathon_path(@meta_appathon), class: 'btn btn-danger btn-block' do %>
                <span class="fa fa-bolt fa-fw"></span> Host an App-a-thon
              <% end %>
            <% end %>
          </div>
          <% end %>
          <%= render "appathons/cards", meta_appathon: @meta_appathon, appathons: @appathons %>
        </div>
        <div class="pfda-pane-content">
          <%= render "meta_appathons/app_cards", apps: @apps, meta_appathon: @meta_appathon %>
        </div>
      </div>
    </div>
  </div>

</div>
