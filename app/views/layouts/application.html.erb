<!DOCTYPE html>
<html>
<head>
  <%= render "_partials/header" %>
</head>
<body class="pfda-controller-<%= controller_name %> pfda-action-<%= action_name %>" data-controller="<%= controller_name %>" data-action="<%= action_name %>">
