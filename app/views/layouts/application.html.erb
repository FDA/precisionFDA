<!DOCTYPE html>
<html lang="en-US">
<head>
  <%= render "_partials/header" %>
</head>
<body class="pfda-controller-<%= controller_name %> pfda-action-<%= action_name %> <% if !@context.logged_in? %>pfda-guest<% else %>pfda-user<% end %>">
  <noscript>This website requires JavaScript</noscript>
  <header>
    <%= render "_partials/navbar" %>
  </header>
  <main role="main">
    <%= render partial: "_partials/messages", flash: flash %>
    <%= yield %>
  </main>
  <footer>
    <%= render "_partials/footer" %>
  </footer>
  <%= insert_paloma_hook %>
  <%= render "_partials/templates" %>
</body>
  <%= render "_partials/scripts" %>
</html>
