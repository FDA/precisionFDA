<% content_for :title do %>Overview<% end %>

<% if !@context.logged_in? %>
  <div class="jumbotron jumbotron-landing jumbotron-landing-guest jumbotron-particles jumbotron-particles-top">
    <div class="container">
      <div class="pfda-brand">
        <%= image_tag("precisionFDA.white.navbar-guest.png") %>
      </div>
      <div class="guest-actions">
        <p class="lead">A community platform for NGS assay evaluation and regulatory science exploration.</p>
        <%= render "_partials/guest_actions" %>
      </div>
    </div>
  </div>

  <div class="jumbovideo">
    <div class="jumbovideo-player-wrapper">
      <div id="ytplayer" class="jumbovideo-player"></div>
    </div>
  </div>

  <script>
    // Load the IFrame Player API code asynchronously.
    var tag = document.createElement('script');
    tag.src = "https://www.youtube.com/player_api";
    var firstScriptTag = document.getElementsByTagName('script')[0];
    firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);

    // Replace the 'ytplayer' element with an <iframe> and
    // YouTube player after the API code downloads.
    var player;
    function onYouTubePlayerAPIReady() {
      player = new YT.Player('ytplayer', {
        width: '100%',
        videoId: 'kn4J4bqJG2Q',
        playerVars: {
          autoplay: 1,
          controls: 0,
          loop: 1,
          playlist: 'kn4J4bqJG2Q', // To make loop work
          modestbranding: 1,
          rel: 0,
          playsinline: 1,
          showinfo: 0,
        },
        events: {
          'onReady': onPlayerReady
        }
      });
    }

    function onPlayerReady(event) {
      event.target.mute();
      event.target.setVolume(0);
    }
  </script>
<% else %>
  <div class="jumbotron jumbotron-landing jumbotron-particles">
    <div class="container">
      <h1>WELCOME to precisionFDA</h1>
      <p class="lead">A community platform for NGS assay evaluation and regulatory science exploration.</p>
    </div>
  </div>
<% end %>

<div class="showcase container">
  <div class="row">
    <div class="showcase-item col-md-6">
      <div class="showcase-icon">
        <span class="fa fa-files-o"></span>
      </div>
      <div class="showcase-content">
        <div class="showcase-heading">Files</div>
        <p class="lead">Files are data you can upload to the platform and use as input to apps or comparisons</p>
      </div>
    </div>

    <div class="showcase-item col-md-6">
      <div class="showcase-icon">
        <span class="fa fa-bullseye"></span>
      </div>
      <div class="showcase-content">
        <div class="showcase-heading">Comparisons</div>
        <p class="lead">A comparison quantifies the similarity between two VCF files: a test set and a benchmark set</p>
      </div>
    </div>

    <div class="showcase-item col-md-6">
      <div class="showcase-icon">
        <span class="fa fa-cubes"></span>
      </div>
      <div class="showcase-content">
        <div class="showcase-heading">Apps</div>
        <p class="lead">Apps are executable scripts that you can run in the cloud to perform custom analysis</p>
      </div>
    </div>

    <div class="showcase-item col-md-6">
      <div class="showcase-icon">
        <span class="fa fa-sticky-note"></span>
      </div>
      <div class="showcase-content">
        <div class="showcase-heading">Notes</div>
        <p class="lead">
          Notes let you communicate your analysis procedure and what data you used to accomplish it
        </p>
      </div>
    </div>
  </div>
</div>

<% if !@context.logged_in? %>
<div class="guest-actions">
  <%= render "_partials/guest_actions" %>
</div>
<% end %>