<% content_for :title do %>Request Access<% end %>

<div class="page-header">
  <div class="container">
    <div class="row">
      <div class="col-sm-10 col-sm-offset-5">
        <div class="page-title">
          <div class="">Request Access to precisionFDA</div>
        </div>
        <hr>
        <div class="description">
          <% if @invitation.new_record? %>
            <p class="lead">
              Thank you for your interest!
              <br>
              <small>
                We are currently in closed beta. Please leave your information below,
                to register your request. You will hear back from us in the
                coming weeks, once the beta opens up.
              </small>
            </p>
          <% else %>
            <p class="lead text-success">
              <span class="fa fa-check"></span> Thank you! Your request has been registered. You will hear back from us in the coming weeks, once the beta opens up.
            </p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<% if @invitation.new_record? %>
  <div class="container">
    <div class="row">
      <%= form_for @invitation, url: request_access_path, html: {class: "form form-horizontal"} do |f| %>
        <% if @invitation.errors.any? %>
          <div class="form-group form-group-lg">
            <div class="alert alert-danger col-md-10 col-md-offset-5">
              <strong><span class="fa fa-warning"></span> Please correct the following errors:</strong>
              <ul>
                <% @invitation.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        <% end %>
        <div class="form-group form-group-lg text-uppercase">
          <div class="col-sm-offset-5 col-sm-10">
            About me
          </div>
          <hr>
        </div>
        <div class="form-group form-group-lg">
          <%= f.label :first_name, "First name", class: 'control-label col-sm-4' %>
          <div class="col-sm-10 col-sm-offset-1">
            <%= f.text_field :first_name, class: 'form-control input-lg', placeholder: '', required: 'required' %>
          </div>
        </div>
        <div class="form-group form-group-lg">
          <%= f.label :last_name, "Last name", class: 'control-label col-sm-4' %>
          <div class="col-sm-10 col-sm-offset-1">
            <%= f.text_field :last_name, class: 'form-control input-lg', required: 'required' %>
          </div>
        </div>
        <div class="form-group form-group-lg">
          <%= f.label :email, "Email address", class: 'control-label col-sm-4' %>
          <div class="col-sm-10 col-sm-offset-1">
            <%= f.email_field :email, class: 'form-control input-lg', required: 'required' %>
          </div>
        </div>
        <div class="form-group form-group-lg">
          <%= f.label :org, "Organization", class: 'control-label col-sm-4' %>
          <div class="col-sm-5 col-sm-offset-1">
            <%= f.text_field :org, class: 'form-control input-lg' %>
          </div>
          <div class="col-sm-1 hidden-xs">
            <div class="form-control-static">
              <strong>OR</strong>
            </div>
          </div>
          <div class="col-sm-8">
            <div class="checkbox">
              <label>
                <%= f.check_box :singular %>
                I do not represent any organization
              </label>
            </div>
          </div>
        </div>
        <div class="form-group form-group-lg">
          <%= f.label :address, "Address", class: 'control-label col-sm-4' %>
          <div class="col-sm-10 col-sm-offset-1">
            <%= f.text_field :address, class: 'form-control input-lg', required: 'required' %>
          </div>
        </div>
        <div class="form-group form-group-lg">
          <%= f.label :phone, "Phone #", class: 'control-label col-sm-4' %>
          <div class="col-sm-10 col-sm-offset-1">
            <%= f.telephone_field :phone, class: 'form-control input-lg', required: 'required' %>
          </div>
        </div>
        <div class="form-group form-group-lg form-group-optional">
          <%= f.label :duns, "DUNS #", class: 'control-label col-sm-4' %>
          <div class="col-sm-10 col-sm-offset-1">
            <%= f.text_field :duns, class: 'form-control input-lg' %>
          </div>
        </div>
        <div class="form-group form-group-lg text-uppercase">
          <div class="col-sm-offset-5 col-sm-10">
            My access to precisionFDA
          </div>
          <hr>
        </div>
        <div class="form-group form-group-lg">
          <div class="col-sm-offset-5 col-sm-10">
            Tell us a bit more about your goals / reasons why are requesting access:
          </div>
        </div>
        <div class="form-group form-group-lg">
          <div class="col-sm-10 col-sm-offset-5">
            <%= f.text_field :req_reason, class: 'form-control input-lg', required: 'required' %>
          </div>
        </div>
        <div class="form-group form-group-lg form-group-optional">
          <div class="col-sm-offset-5 col-sm-10">
            Do you have any data to contribute? If so, list below.
          </div>
        </div>
        <div class="form-group form-group-lg form-group-optional">
          <div class="col-sm-10 col-sm-offset-5">
            <%= f.text_field :req_data, class: 'form-control input-lg' %>
          </div>
        </div>
        <div class="form-group form-group-lg">
          <div class="col-sm-offset-5 col-sm-10">
            Do you have any software to contribute? If so, list below.
          </div>
        </div>
        <div class="form-group form-group-lg form-group-optional">
          <div class="col-sm-10 col-sm-offset-5">
            <%= f.text_field :req_software, class: 'form-control input-lg' %>
          </div>
        </div>
        <div class="form-group form-group-lg">
          <div class="col-sm-offset-5 col-sm-10">
            Prove you are not a robot by answering the following question: <br>
            <%= @invitation.humanizer_question %>
          </div>
        </div>
        <div class="form-group form-group-lg">
          <%= f.label :humanizer_answer, "Answer", class: 'control-label col-sm-4' %>
          <div class="col-sm-10 col-sm-offset-1">
            <%= f.text_field :humanizer_answer, class: 'form-control input-lg', required: 'required' %>
          </div>
          <%= f.hidden_field :humanizer_question_id %>
        </div>
        <div class="form-group form-group-lg">
            <div class="col-sm-offset-5 col-sm-10">
              <%= f.submit "Request Access to precisionFDA", class: "btn btn-lg btn-success" %>
            </div>
         </div>
      <% end %>
    </div>
  </div>
<% end %>

<%= render "_partials/fda_footer" %>
