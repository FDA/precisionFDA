<% content_for :title do %>Request Access<% end %>

<div class="page-header">
  <div class="container">
    <div class="row">
      <div class="col-sm-10 col-sm-offset-5">
        <div class="page-title">
          <div class="">Request Access to precisionFDA</div>
        </div>
        <hr>
        <div class="description">
          <p class="lead">
            Thank you for your interest!
            <br>
            <small>
              We are currently in a closed beta and will be releasing access requests in the coming weeks.
            </small>
            <br>
            <small>
              Please leave your information if you are interested in an invite.
            </small>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="container">
  <div class="row">
    <%= form_for :user, url: request_access_path, html: {class: "form form-horizontal"} do |f| %>
      <div class="form-group form-group-lg">
        <%= label_tag :first_name, "First name", class: 'control-label col-sm-4' %>
        <div class="col-sm-10 col-sm-offset-1">
          <%= f.text_field :first_name, class: 'form-control input-lg', placeholder: '', required: 'required' %>
        </div>
      </div>
      <div class="form-group form-group-lg">
        <%= label_tag :last_name, "Last name", class: 'control-label col-sm-4' %>
        <div class="col-sm-10 col-sm-offset-1">
          <%= f.text_field :last_name, class: 'form-control input-lg', required: 'required' %>
        </div>
      </div>
      <div class="form-group form-group-lg">
        <%= label_tag :email, "Email address", class: 'control-label col-sm-4' %>
        <div class="col-sm-10 col-sm-offset-1">
          <%= f.email_field :email, class: 'form-control input-lg', required: 'required' %>
        </div>
      </div>
      <div class="form-group form-group-lg">
        <%= label_tag :org, "Organization", class: 'control-label col-sm-4' %>
        <div class="col-sm-5 col-sm-offset-1">
          <%= f.text_field :org, class: 'form-control input-lg' %>
        </div>
        <div class="col-sm-1 hidden-xs">
          <div class="form-control-static">
            <strong>OR</strong>
          </div>
        </div>
        <div class="col-sm-5">
          <div class="checkbox">
            <label>
              <%= f.check_box :has_no_org %>
              I represent myself
            </label>
          </div>
        </div>
      </div>
      <div class="form-group form-group-lg">
        <%= label_tag :address, "Address", class: 'control-label col-sm-4' %>
        <div class="col-sm-10 col-sm-offset-1">
          <%= f.text_field :address, class: 'form-control input-lg', required: 'required' %>
        </div>
      </div>
      <div class="form-group form-group-lg">
        <%= label_tag :phone, "Phone #", class: 'control-label col-sm-4' %>
        <div class="col-sm-10 col-sm-offset-1">
          <%= f.telephone_field :phone, class: 'form-control input-lg', required: 'required' %>
        </div>
      </div>
      <div class="form-group form-group-lg form-group-optional">
        <%= label_tag :duns, "DUNS #", class: 'control-label col-sm-4' %>
        <div class="col-sm-10 col-sm-offset-1">
          <%= f.text_field :duns, class: 'form-control input-lg' %>
        </div>
      </div>
      <div class="form-group form-group-lg">
          <div class="col-sm-offset-5 col-sm-10">
            <%= submit_tag("Request Access to precisionFDA", class: "btn btn-lg btn-success") %>
          </div>
       </div>
    <% end %>
  </div>
</div>
