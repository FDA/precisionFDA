<% content_for :title do %>Publisher<% end %>

<div class="container">
  <div class="alert alert-warning">
    <p class="lead"><span class="fa fa-fw fa-info-circle"></span> Thank you for your interest in publishing. This feature has not been rolled out yet.</p>
    <p>In the meantime, you can review the dependency graph of the item you want to publish below. The item you want to publish is represented in the root of the graph, and its dependencies (if any) are represented as nodes below. Nodes marked in green are already public.
    </p>
    <p><strong>This rendering is experimental</strong></p>
  </div>
</div>

<div class="publisher-canvas-wrapper">
  <svg class="publisher-canvas"><g/></svg>
</div>

<script src="https://cpettitt.github.io/project/dagre-d3/latest/dagre-d3.js"></script>
<script>
var g = new dagreD3.graphlib.Graph().setGraph({});

<%= raw graph_nodes(@graph) %>
<%= raw graph_edges(@graph) %>

var svg = d3.select("svg.publisher-canvas"),
    inner = svg.select("g");

var render = new dagreD3.render();
render(inner, g);

svg.attr("height", g.graph().height + 2);
svg.attr("width", g.graph().width + 2);
</script>
