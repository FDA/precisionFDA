<% content_for :title do %>Run <%= @app.title %><% end %>

<div>Run <%= @app.title %></div>
<hr>
<%= form_for @job, url: app_jobs_path(@app.dxid) do |f| %>

  <%= f.label :name, "Name" %>
  <%= f.text_field :name %>

  <hr>

  <div> Inputs: </div>
  <%= f.fields_for :run_inputs do |f| %>
    <% @app.input_spec.each do |input| %>
      <%
      is_required = (input['optional'] != true)
      default = input['default']
      klass = input['class']
      label = input['label']
      help = input['help']
      name = input['name']
      choices = input['choices']
      %>
      <div>
      <%= f.label name, label, title: help %>
      <% if klass == 'string' %>
        <% if choices.present? %>
          <%= f.select(name, choices, include_blank: !is_required, :prompt => 'Select...') %>
        <% else %>
          <%= f.text_field name %>
        <% end %>
      <% elsif klass == 'int' %>
        <%= f.text_field name %>
      <% elsif klass == 'boolean' %>
        <%= f.check_box name %>
      <% elsif klass == 'file' %>
        <%= f.collection_select(name, @files, :dxid, :name, :prompt => 'Select...') %>
      <% end %>
      </div>
    <% end %>
  <% end %>
  <%= f.submit "Run App" %>
<% end %>

<br>
<button type="button" id="btn" onclick="tst();">Test</button>

<script>
function apiCall(route, input, cb) {
  $.ajax(route, {
    "contentType": "application/json",
    "data": JSON.stringify(input),
    "dataType": "json",
    "error": function(xhr, status, err) { alert("ERROR! XHR status = " + status + ", error = " + err); },
    "jsonp": false,
    "method": "POST",
    "mimeType": "application/json",
    "processData": false,
    "success": function(data, status, xhr) { cb(data); }
  });
}
function tst() {
  var input = {
    id: "app-BjPzf380zBFQBf9qg0X7BfBx",
    name: "my first job",
    inputs: {
      "required_file": "file-Bj61YZ80F3xq5Vq58bK5PVz1",
      "required_number": 3,
      "trim": false,
      "required_string": "MiSeq",
      "optional_file": "file-Bj6114Q0F3xzYQ9G9VK67bVX"
    }
  };
  apiCall("/api/run_app", input, function(res) {
    console.dir(res);
  })
}

</script>
