<% content_for :title do %>Biospecimens<% end %>

<%= render "_partials/toolbar", toolbar: @toolbar  %>

<%= grid(@biospecimens, show_filters: :when_filtered) do |g|
  g.blank_slate partial:  "_partials/empty_grid"

  g.after_row do |biospecimen, num_cols|
    if !biospecimen.description.blank?
      content_tag(:tr,
        content_tag(:td,
          content_tag(:div, biospecimen.description, class: 'description'),
        colspan: num_cols),
      class: 'extra-row')
    else
      nil
    end
  end

  g.column name: 'Name', attribute: 'name' do |biospecimen|
    link_to(biospecimen.name, biospecimen_path(biospecimen.id))
  end

  g.column name: 'Added by', attribute: 'dxuser', assoc: :user do |biospecimen|
    link_to(biospecimen.user.dxuser, user_path(biospecimen.user.dxuser))
  end

  g.column name: '# of Files' do |biospecimen|
    link_to(biospecimen.user_files.accessible_by(@context.user_id).size, "#{files_path()}?grid[f][biospecimen.name]=#{biospecimen.name}")
  end

  g.column name: 'Created', attribute: 'created_at', auto_reload: true, filter_type: :standard do |file|
    file.created_at.to_s(:db)
  end

  g.column name: 'Updated', attribute: 'updated_at', auto_reload: true, filter_type: :standard do |biospecimen|
    biospecimen.updated_at.to_s(:db)
  end
end -%>
