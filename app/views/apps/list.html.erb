<% content_for :title do %>Apps<% end %>

<div class="pfda-toolbar">
  <div class="btn-group pull-right">
    <a class="btn btn-default" href="<%= assets_path %>"><span class="fa fa-file-zip-o fa-fw"></span> Manage Assets</a>
    <a class="btn btn-primary" href="<%= new_app_path %>"><span class="fa fa-plus-square fa-fw"></span> Create App</a>
  </div>
  <ul class="nav nav-pills nav-pills-sm">
    <li class="<% if action_name == 'index' %>active<% end %>">
      <%= link_to apps_path do %>
        <span class="fa fa-cubes"></span> <span class="pill-label">Relevant Apps</span>
      <% end %>
    </li>
    <li class="<% if action_name == 'featured' %>active<% end %>">
      <%= link_to featured_apps_path do %>
        <span class="fa fa-flag"></span> <span class="pill-label">Featured</span>
      <% end %>
    </li>
    <li class="<% if action_name == 'explore' %>active<% end %>">
      <%= link_to explore_apps_path do %>
        <span class="fa fa-globe"></span> <span class="pill-label">Explore</span>
      <% end %>
    </li>
  </ul>
</div>

<% if @apps.present? && @apps.count > 0 %>
  <%= render "apps/cards", apps: @apps %>
<% else %>
  <div class="container-fluid container-padded">
    <div class="alert alert-info">
      We couldn't find any apps here
    </div>
  </div>
<% end %>
