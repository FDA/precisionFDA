<% content_for :title do %>Apps<% end %>

<div class="pfda-pane container-fluid">
  <div class="pfda-pane-sidebar pfda-pane-sidebar-dark">
    <div class="pfda-toolbar">
      <div class="btn-group">
        <a class="btn btn-default" href="<%= new_app_path %>"><span class="fa fa-plus-square fa-fw"></span> Create App</a>
        <a class="btn btn-default" href="<%= assets_path %>"><span class="fa fa-file-zip-o fa-fw"></span> Manage Assets</a>
      </div>
    </div>
    <div class="list-group">
      <a href="<%= apps_path() %>" class="list-group-item <%= @app.nil? ? 'active' : '' %>">
        <span class="fa fa-tasks"></span> Jobs for All Apps
      </a>
    </div>
    <div class="list-group">
      <%= render "_partials/apps_list_group", apps: @apps, active: @app.try(:app_series_id) %>
    </div>
  </div>
  <div class="pfda-pane-content">
    <%= render "/apps/detail", app: @app, jobs_grid: @jobs_grid %>
  </div>
</div>
