<div class="container-fluid">
  <div class="pfda-cards">
    <% @notes.each do |note| %>
      <a class="pfda-card pfda-card-has-metadata pfda-card-padded pfda-card-rounded pfda-card-bordered" href="<%= note_path(note) %>">
        <div class="pfda-card-header">
          <div class="pfda-card-title">
            <%= truncate(note.title, :length => 40,  :separator => ' ')%>
          </div>
        </div>
        <div class="pfda-card-body">
          <%= truncate(note.content, :length => 200,  :separator => ' ')%>
        </div>
        <div class="pfda-card-metadata">
          <ul class="list-inline">
            <% if note.real_files.count > 0 %>
              <li title="Files"><span class="pfda-card-metadata-value"><%= note.real_files.count %></span> <span class="fa fa-files-o"></span></li>
            <% end %>
            <% if note.comparisons.count > 0 %>
              <li title="Comparisons"><span class="pfda-card-metadata-value"><%= note.comparisons.count %></span> <span class="fa fa-bullseye"></span></li>
            <% end %>
            <% if note.apps.count > 0 %>
              <li title="Apps"><span class="pfda-card-metadata-value"><%= note.apps.count %></span> <span class="fa fa-cubes"></span></li>
            <% end %>
            <% if note.jobs.count > 0 %>
              <li title="Jobs"><span class="pfda-card-metadata-value"><%= note.jobs.count %></span> <span class="fa fa-tasks"></span></li>
            <% end %>
            <li class="pull-right"><small><%= note.user.dxuser %></small></li>
          </ul>
        </div>
      </a>
    <% end %>
  </div>
</div>
